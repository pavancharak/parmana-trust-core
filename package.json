{
  "name": "parmana-trust-core",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "vitest run",
    "lint": "turbo run lint",
    "openapi:lint": "redocly lint openapi/openapi.yaml",
    "openapi:bundle": "redocly bundle openapi/openapi.yaml -o openapi/dist/openapi.yaml",
    "verify": "tsx apps/cli/src/verify.ts",
    "receipt": "tsx apps/cli/src/receipt.ts",
    "playground:bundle": "tsx apps/playground/bundle-roundtrip.ts",
    "playground:verify": "tsx apps/playground/decision-test.ts",
    "playground:trust-root": "tsx apps/playground/trust-root-test.ts"
  },
  "devDependencies": {
    "@redocly/cli": "^2.34.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "supabase": "^2.106.0",
    "tsx": "^4.19.0",
    "turbo": "^2.0.14",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@supabase/supabase-js": "^2.108.2",
    "axios": "^1.18.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  }
}
