{
  "policyId": "payment-release",
  "policyVersion": "1.0.0",
  "schemaVersion": "1.0.0",

  "signalsSchema": {
    "amount": {
      "type": "integer"
    },
    "currency": {
      "type": "string"
    },
    "recipient": {
      "type": "string"
    }
  },

  "rules": [
    {
      "id": "approve-payment",
      "condition": {
        "all": [
          {
            "signal": "amount",
            "greater_than": 0
          }
        ]
      },
      "outcome": {
        "action": "approve",
        "requires_override": false,
        "reason": "payment_authorized"
      }
    },

    {
      "id": "catch-all-reject",
      "condition": {
        "all": []
      },
      "outcome": {
        "action": "reject",
        "requires_override": true,
        "reason": "payment_requirements_not_satisfied"
      }
    }
  ]
}